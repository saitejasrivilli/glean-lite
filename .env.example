# Copy to .env for local development (never commit this file)

# Qdrant Cloud — get from cloud.qdrant.io
QDRANT_ADDR=your-cluster-id.cloud.qdrant.io:6334
QDRANT_API_KEY=your-qdrant-api-key

# Groq — get from console.groq.com (free)
GROQ_API_KEY=gsk_...

# HuggingFace — get from huggingface.co/settings/tokens (free)
HF_API_KEY=hf_...

# GitHub — Personal Access Token with repo:read scope
GITHUB_TOKEN=ghp_...

# Comma-separated list of repos to index
# These become your live demo corpus — index your own projects!
GITHUB_REPOS=yourname/glean-lite,yourname/other-repo

# Optional: override default embedding model
# EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

PORT=8080
